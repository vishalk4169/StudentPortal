@model StudentPortal.Models.Student

@{
    ViewData["Title"] = "Add Student";
}

<style>

    body{
        background-color:#f4f6f9;
        font-family:Arial, Helvetica, sans-serif;
    }

    .form-container{
        width:500px;
        margin:40px auto;
        background:white;
        padding:40px;
        border-radius:20px;
        box-shadow:0px 8px 20px rgba(0,0,0,0.1);
    }

    .form-title{
        text-align:center;
        font-size:38px;
        font-weight:bold;
        color:#2c3e50;
        margin-bottom:35px;
    }

    .input-group{
        margin-bottom:22px;
    }

    label{
        font-weight:bold;
        color:#2c3e50;
        display:block;
        margin-bottom:8px;
    }

    input,
    select,
    textarea{
        width:100%;
        padding:14px;
        border-radius:10px;
        border:1px solid #ccc;
        font-size:16px;
        transition:0.3s;
        box-sizing:border-box;
    }

    input:focus,
    select:focus,
    textarea:focus{
        border-color:#3498db;
        outline:none;
        box-shadow:0px 0px 8px rgba(52,152,219,0.4);
    }

    .gender-box{
        display:flex;
        gap:30px;
        margin-top:10px;
    }

    .gender-option{
        display:flex;
        align-items:center;
        gap:8px;
        font-size:18px;
    }

    .submit-btn{
        width:100%;
        padding:15px;
        background-color:#3498db;
        color:white;
        border:none;
        border-radius:12px;
        font-size:20px;
        font-weight:bold;
        cursor:pointer;
        transition:0.3s;
        margin-top:10px;
    }

    .submit-btn:hover{
        background-color:#2980b9;
        transform:translateY(-3px);
    }

</style>

<div class="form-container">

    <div class="form-title">
        Add Student
    </div>

    <form method="post">

        <!-- NAME -->

        <div class="input-group">

            <label>Name</label>

            <input asp-for="Name"
                   placeholder="Enter full name" />

        </div>

        <!-- EMAIL -->

        <div class="input-group">

            <label>Email</label>

            <input asp-for="Email"
                   type="email"
                   placeholder="Enter email address" />

        </div>

        <!-- PHONE -->

        <div class="input-group">

            <label>Phone Number</label>

            <input asp-for="Phone"
                   placeholder="Enter phone number" />

        </div>

        <!-- GENDER -->

        <div class="input-group">

            <label>Gender</label>

            <div class="gender-box">

                <div class="gender-option">

                    <input type="radio"
                           asp-for="Gender"
                           value="Male" />

                    <span>Male</span>

                </div>

                <div class="gender-option">

                    <input type="radio"
                           asp-for="Gender"
                           value="Female" />

                    <span>Female</span>

                </div>

            </div>

        </div>

        <!-- DOB -->

        <div class="input-group">

            <label>Date of Birth</label>

            <input type="date"
                   asp-for="DOB" />

        </div>

        <!-- COURSE -->

        <div class="input-group">

            <label>Course</label>

            <select asp-for="Course">

                <option value="">Select Course</option>

                <option>CSE</option>
                <option>CE</option>
                <option>IT</option>
                <option>EXTC</option>

            </select>

        </div>

       

        <!-- BUTTON -->

        <button type="submit" class="submit-btn">
            Save Student
        </button>

    </form>

</div>